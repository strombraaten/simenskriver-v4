---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { shouldShowPost, postUrl } from '@/utils/markdown';
import PostLayout from '@/layouts/PostLayout.astro';

// Single posts handler — all content lives in the posts collection.
// Routes use permalink if set, otherwise the post's id (filename without extension).
// Posts with draft: true are excluded from production builds.
export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts');
  const isDev = import.meta.env.DEV;
  const visiblePosts = posts.filter(post => shouldShowPost(post, isDev));

  return visiblePosts.map(post => {
    const slug = postUrl(post).slice(1); // postUrl returns '/{slug}', strip leading slash
    return { params: { slug }, props: { post } };
  });
};

const { post } = Astro.props;

const isDev = import.meta.env.DEV;
if (!shouldShowPost(post, isDev)) return Astro.redirect('/404');
---

<PostLayout post={post} />
