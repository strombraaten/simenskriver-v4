---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { shouldShowPost, postUrl } from '@/utils/markdown';

// Legacy /posts/{id} URLs — issue 301 redirects to canonical root-level URLs.
// This preserves backward compatibility for any existing links or bookmarks.
export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts');
  const isDev = import.meta.env.DEV;
  const visiblePosts = posts.filter(post => shouldShowPost(post, isDev));

  return visiblePosts.map(post => ({
    params: { slug: post.id },
    props: { post }
  }));
};

const { post } = Astro.props;

if (!post || !shouldShowPost(post, import.meta.env.DEV)) {
  return Astro.redirect('/404');
}

// Redirect to canonical permalink-based URL
const targetUrl = postUrl(post);
return Astro.redirect(targetUrl, 301);
---
